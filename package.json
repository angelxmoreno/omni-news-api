{
    "name": "omni-news-api",
    "version": "0.1.0",
    "description": "OmniNewsAPI: A flexible RSS adapter that fetches and normalizes news articles from any RSS feed.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "keywords": [
        "rss",
        "news",
        "feed",
        "rss-parser",
        "xml",
        "adapter",
        "news-aggregator",
        "articles",
        "feed-reader"
    ],
    "author": "Angel S. Moreno <angelxmoreno@gmail.com>",
    "license": "MIT",
    "private": false,
    "repository": {
        "type": "git",
        "url": "git@github.com:angelxmoreno/omni-news-api.git"
    },
    "scripts": {
        "prepare": "lefthook install",
        "build": "tsc",
        "prepublishOnly": "bun run test && bun run lint",
        "test": "bun test",
        "test:unit": "bun test tests/unit",
        "test:integration": "bun test tests/integration",
        "lint": "biome check .",
        "lint:fix": "biome check --write",
        "lint:commits": "commitlint --from=origin/main --to=HEAD --verbose",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@keyvhq/core": "^2.1.7",
        "axios": "^1.11.0",
        "axios-cache-interceptor": "^1.8.2",
        "axios-cache-interceptor-keyv": "^1.1.0",
        "axios-date-transformer": "^1.2.1",
        "fast-xml-parser": "^5.2.5",
        "pino": "^9.9.0",
        "zod": "^4.0.17"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.0",
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "axios-mock-adapter": "^2.1.0",
        "lefthook": "^1.12.3",
        "@types/bun": "^1.2.20",
        "typescript": "^5.9.2"
    }
}
